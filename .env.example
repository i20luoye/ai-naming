# Runtime
NODE_ENV=development
APP_ENV=DEV
HOSTNAME=localhost
PORT=5000

# Site URL (used for sitemap, robots, canonical URLs, JSON-LD)
# Set to your production domain in deployment, e.g. https://tianyan.app
# Do NOT hardcode localhost as the production address.
NEXT_PUBLIC_SITE_URL=http://localhost:5000

# LLM
# Do not commit real secrets. Fill these in local or deployment environment only.
# Used by /api/generate-names and scripts/live-llm-regression.ts.
# Used by live regression runs.
LLM_API_KEY=
LLM_BASE_URL=https://apihub.agnes-ai.com/v1
LLM_MODEL=agnes-2.0-flash

# Reserved for later productionization. Current MVP does not persist business data.
DATABASE_URL=
REDIS_URL=
